# WingBuddy server — environment variable NAMES only (no secrets here).
# Copy to .env.local and fill in real values.

# --- Vocal Bridge ---
# VB API key: used for `vb` CLI auth AND server-side token minting (X-API-Key).
# Confirm whether this is an agent-scoped key (works directly) or an account key
# (then set VB_AGENT_ID and run `vb agent use <id>`).
VOICE_BRIDGE_WINGBUDDY=
# REQUIRED (account key): the hosted agent id. VB mints tokens per (user, agent),
# and the server sends this as X-Agent-Id. Get it from `vb agent list` / dashboard,
# or scripts/vb-setup.sh creates one. Agent "WingBuddy" already exists in this account.
VB_AGENT_ID=

# --- Sabre (REAL) ---
SABRE_APP_USERNAME=
SABRE_APP_PASS=
SABRE_PCC=
SABRE_DOMAIN=AS
SABRE_BASE_URL=https://api-crt.cert.havail.sabre.com
SABRE_TEST_PNR=
# real | mock  (mock = deterministic fixtures / demo fallback / no creds)
SABRE_MODE=real

# --- App ---
# HMAC secret for signed joiner `t` links and requesterKey.
ACCESS_TOKEN_SECRET=
# lib/translate.ts (claude-haiku-4-5)
ANTHROPIC_API_KEY=
# This server's public URL.
NEXT_PUBLIC_APP_URL=
# Comma-separated allowed client origins for CORS (the separate client app).
CORS_ALLOWED_ORIGINS=

# --- Session store (Upstash Redis) ---
# REQUIRED on Vercel (multi-instance serverless): the in-memory store only works
# on a single warm instance. When BOTH are set, lib/session-store.ts uses Redis;
# otherwise it falls back to an in-memory Map (fine for local dev + tests).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
